{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Explorer",
  "version": "0.1.0",
  "identifier": "com.ilios.explorer",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Explorer",
        "width": 1320,
        "height": 840,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/YannickHerrero/Explorer/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCQTlGQjEzMEU4QjIwQkQKUldTOUlJc09FL3VwaTRxYjVzNHFqUU42QVZoWWRJai9tREoxdWxDejI0UG5IZFU0aFNQMWhiWGMK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
